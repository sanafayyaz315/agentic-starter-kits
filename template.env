# API_KEY=
# BASE_URL=
# MODEL_ID=
# CONTAINER_IMAGE=

# Set MLFLOW_TRACKING_URI and other MLflow environment variables to enable local MLflow tracing.
# If MLFLOW_TRACKING_URI is set, tracing will be active. Ensure the MLflow server is running before starting the application.

## LOCAL TRACING 

# MLFLOW_TRACKING_URI=
# MLFLOW_EXPERIMENT_NAME=
# MLFLOW_HTTP_REQUEST_TIMEOUT=     # (default is 120s)
# MLFLOW_HTTP_REQUEST_MAX_RETRIES=

## OPENSHIFT CLUSTER TRACING

# Openshift Cluster
# MLFLOW_TRACKING_URI=
# MLFLOW_TRACKING_TOKEN=
# MLFLOW_EXPERIMENT_NAME=
# MLFLOW_TRACKING_INSECURE_TLS=
# MLFLOW_WORKSPACE=
# MLFLOW_TRACKING_AUTH= # Use Kubernetes service account for authentication (if running inside the cluster)

# RAG-specific Configuration (only needed for RAG agents)
# VECTOR_STORE_PATH=
# EMBEDDING_MODEL=
# DOCS_TO_LOAD=
# PORT=