# API_KEY=
# BASE_URL=
# MODEL_ID=
# CONTAINER_IMAGE=

# Set MLFLOW_TRACKING_URI and other MLflow environment variables to enable local MLflow tracing.
# If MLFLOW_TRACKING_URI is set, tracing will be active. Ensure the MLflow server is running before starting the application.

## LOCAL TRACING 

# MLFLOW_TRACKING_URI="http://localhost:5000"
# MLFLOW_EXPERIMENT_NAME="Langgraph Local Experiment"
# MLFLOW_HTTP_REQUEST_TIMEOUT=2        # Fail after 2 seconds (default is 120s)
# MLFLOW_HTTP_REQUEST_MAX_RETRIES=0  

## OPENSHIT CLUSTER TRACING

# Openshift Cluster
# MLFLOW_TRACKING_URI="https://<openshift-dashboard-url>/mlflow"
# MLFLOW_TRACKING_TOKEN="<your-openshift-token>"
# MLFLOW_EXPERIMENT_NAME="Cluster Demo"
# MLFLOW_TRACKING_INSECURE_TLS="true" # If the OpenShift cluster does not use trusted certificates
# MLFLOW_WORKSPACE="<your project name>"
# MLFLOW_TRACKING_AUTH="kubernetes" # Use Kubernetes service account for authentication (if running inside the cluster)

# RAG-specific Configuration (only needed for RAG agents)
# VECTOR_STORE_PATH=
# EMBEDDING_MODEL=
# DOCS_TO_LOAD=
# PORT=